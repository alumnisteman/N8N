# ==================== BASIC CONFIGURATION ====================
PROJECT_NAME=affiliate-automation
ENVIRONMENT=development
DOMAIN=yourdomain.com
ACME_EMAIL=your-email@example.com

# ==================== DATABASE CONFIGURATION ====================
POSTGRES_DB=affiliate_db
POSTGRES_USER=affiliate_user
POSTGRES_PASSWORD=your_secure_postgres_password_here

# ==================== REDIS CONFIGURATION ====================
REDIS_PASSWORD=your_secure_redis_password_here

# ==================== AI API KEYS ====================
# Gemini API Key (Google AI)
GEMINI_API_KEY=your_gemini_api_key_here

# ==================== MEDIA API KEYS ====================
# Pexels API Key (Video stock)
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API Key (Video stock alternative)
PIXABAY_API_KEY=your_pixabay_api_key_here

# ==================== AFFILIATE API KEYS ====================
# Shopee Affiliate API
SHOPEE_API_KEY=your_shopee_api_key_here
SHOPEE_PARTNER_ID=your_shopee_partner_id_here

# TikTok Shop Affiliate API
TIKTOK_SHOP_API_KEY=your_tiktok_shop_api_key_here
TIKTOK_SHOP_PARTNER_ID=your_tiktok_shop_partner_id_here

# Tokopedia Affiliate API
TOKOPEDIA_API_KEY=your_tokopedia_api_key_here
TOKOPEDIA_CLIENT_ID=your_tokopedia_client_id_here
TOKOPEDIA_CLIENT_SECRET=your_tokopedia_client_secret_here

# ==================== SOCIAL MEDIA CREDENTIALS ====================
# TikTok Credentials
TIKTOK_USERNAME=your_tiktok_username
TIKTOK_PASSWORD=your_tiktok_password
TIKTOK_API_KEY=your_tiktok_api_key_here

# Instagram Credentials
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_API_KEY=your_instagram_api_key_here

# Facebook Credentials
FACEBOOK_USERNAME=your_facebook_username
FACEBOOK_PASSWORD=your_facebook_password
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here

# ==================== NOTIFICATION CONFIGURATION ====================
# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# WhatsApp Business API (Optional)
WHATSAPP_API_KEY=your_whatsapp_api_key_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

# ==================== N8N CONFIGURATION ====================
N8N_HOST=n8n.yourdomain.com
N8N_EDITOR_BASE_URL=https://n8n.yourdomain.com
N8N_ENCRYPTION_KEY=your_random_encryption_key_min_32_chars
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_n8n_password
WEBHOOK_URL=https://n8n.yourdomain.com/webhook

# ==================== API CONFIGURATION ====================
# FastAPI
API_HOST=api.yourdomain.com
API_PORT=8000
JWT_SECRET=your_jwt_secret_key_minimum_32_characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ==================== WORKER CONFIGURATION ====================
# Worker AI
WORKER_AI_MAX_CONCURRENT=3
WORKER_AI_TIMEOUT=300

# Worker Render
WORKER_RENDER_MAX_CONCURRENT=2
WORKER_RENDER_TIMEOUT=600

# Worker Upload
WORKER_UPLOAD_MAX_CONCURRENT=3
WORKER_UPLOAD_TIMEOUT=300

# Worker Media
WORKER_MEDIA_MAX_CONCURRENT=5
WORKER_MEDIA_TIMEOUT=180

# Worker Analytics
WORKER_ANALYTICS_MAX_CONCURRENT=5
WORKER_ANALYTICS_TIMEOUT=120

# ==================== MONITORING CONFIGURATION ====================
# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_secure_grafana_password

# Prometheus
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=10GB

# Loki
LOKI_RETENTION_PERIOD=168h

# ==================== BROWSERLESS CONFIGURATION ====================
BROWSERLESS_MAX_CONCURRENT_SESSIONS=5
BROWSERLESS_CONNECTION_TIMEOUT=60000
BROWSERLESS_MAX_QUEUE_LENGTH=10

# ==================== OLLAMA CONFIGURATION ====================
OLLAMA_MODEL=gemma2
OLLAMA_NUM_THREADS=4

# ==================== OPEN WEBUI CONFIGURATION ====================
WEBUI_SECRET_KEY=your_webui_secret_key_minimum_32_characters

# ==================== QDRANT CONFIGURATION ====================
QDRANT_API_KEY=your_qdrant_api_key_here

# ==================== STORAGE CONFIGURATION ====================
# Local temp storage for video processing
TEMP_STORAGE_PATH=/tmp/videos

# ==================== CRON SCHEDULES ====================
# Product Fetch Schedule (Cron expression)
CRON_PRODUCT_FETCH=0 */2 * * *

# Analytics Update Schedule
CRON_ANALYTICS_UPDATE=0 */6 * * *

# Cleanup Schedule
CRON_CLEANUP=0 3 * * *

# ==================== LOGGING CONFIGURATION ====================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_MAX_SIZE=10MB
LOG_MAX_FILES=10

# ==================== SECURITY CONFIGURATION ====================
# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# ==================== BACKUP CONFIGURATION ====================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_S3_BUCKET=your_backup_bucket_name
BACKUP_S3_ACCESS_KEY=your_s3_access_key
BACKUP_S3_SECRET_KEY=your_s3_secret_key
BACKUP_S3_REGION=us-east-1

# ==================== FEATURE FLAGS ====================
FEATURE_AI_GENERATION=true
FEATURE_VIDEO_RENDERING=true
FEATURE_SOCIAL_UPLOAD=true
FEATURE_ANALYTICS=true
FEATURE_NOTIFICATIONS=true

# ==================== PERFORMANCE CONFIGURATION ====================
# Database Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis Connection Pool
REDIS_POOL_SIZE=10
REDIS_MAX_CONNECTIONS=50

# ==================== DEVELOPMENT CONFIGURATION ====================
# Debug Mode (set to false in production)
DEBUG=true

# Hot Reload (set to false in production)
HOT_RELOAD=true

# ==================== PRODUCTION CONFIGURATION ====================
# Set these values when deploying to production
# ENVIRONMENT=production
# DEBUG=false
# HOT_RELOAD=false
# DOMAIN=your-production-domain.com
